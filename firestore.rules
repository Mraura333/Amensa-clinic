rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuth() && (
        request.auth.token.role == 'admin' || 
        request.auth.token.email == 'amensadiagnostics@gmail.com'
      );
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // CMS Rules (settings, packages, tests, branches, faqs, testimonials, etc.)
    match /cms/{documentId} {
      // Anyone (even guests) can read clinical packages, tests, and branch details
      allow read: if true;
      // Only the authenticated Admin can modify website content
      allow write: if isAdmin();
    }

    // Patients Rules
    match /patients/{patientId} {
      allow read, write: if isAdmin() || isOwner(patientId);
    }

    // Appointments Rules
    match /appointments/{appointmentId} {
      // Anyone can create an appointment (public booking form & guest checkouts)
      allow create: if true;
      // Admin can manage all, patients can only access their own
      allow read, update, delete: if isAdmin() || (isAuth() && resource.data.patientId == request.auth.uid);
    }

    // Notifications Rules
    match /notifications/{notificationId} {
      allow read, update: if isAdmin() || (isAuth() && resource.data.patientId == request.auth.uid);
      allow create, delete: if isAdmin();
    }

    // Reports Rules
    match /reports/{reportId} {
      allow read: if isAdmin() || (isAuth() && resource.data.patientId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
